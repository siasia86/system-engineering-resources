{
  "name": "markdown-writer",
  "description": "마크다운 문서 작성 전용 에이전트 (claude-sonnet-4.6)",
  "model": "claude-sonnet-4.6",
  "prompt": "You are a technical documentation writer specializing in infrastructure and system engineering.\n\nRules:\n- Write all documents in Korean\n- Use English for code blocks, commands, and technical terms\n- Follow the markdown style guide in resources\n- Apply README footer template from readme-template skill\n- Apply git commit rules from git-commit-rule skill\n- Concise and direct, no unnecessary filler text",
  "tools": [
    "read",
    "write",
    "shell",
    "aws",
    "delegate",
    "thinking",
    "knowledge"
  ],
  "allowedTools": [
    "execute_bash",
    "fs_read",
    "fs_write",
    "glob",
    "grep",
    "use_aws",
    "use_subagent",
    "web_search",
    "web_fetch"
  ],
  "resources": [
    "skill://work-rules",
    "skill://readme-template",
    "skill://git-commit-rule",
    "skill://md-link-check",
    "skill://code-review",
    "file://~/.kiro/markdown/STYLE.md"
  ],
  "keyboardShortcut": "ctrl+shift+m",
  "welcomeMessage": "마크다운 작성 에이전트입니다 (claude-sonnet-4.6). 문서 작성을 도와드릴게요.",
  "hooks": {
    "preToolUse": [
      {
        "command": "echo \"[$(date +%H:%M:%S)] tool=$TOOL_NAME\" >> /tmp/kiro-markdown-audit.log && [ -n \"$TOOL_INPUT_path\" ] && [ -f \"$TOOL_INPUT_path\" ] && cp \"$TOOL_INPUT_path\" \"/tmp/kiro-diff-before\" || true",
        "tools": ["execute_bash", "fs_write"]
      }
    ],
    "postToolUse": [
      {
        "command": "[ -n \"$TOOL_INPUT_path\" ] && [ -f \"$TOOL_INPUT_path\" ] && [ -f /tmp/kiro-diff-before ] && diff -u /tmp/kiro-diff-before \"$TOOL_INPUT_path\" | head -60 || true",
        "tools": ["fs_write"]
      }
    ]
  }
}
